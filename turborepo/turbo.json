{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": ["NODE_ENV", "API_URL", "NEXT_PUBLIC_API_URL"],
  "ui": "tui",
  "tasks": {
    "generate": {
      "cache": false,
      "outputs": ["generated/**"]
    },
    "build": {
      "dependsOn": ["generate", "^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "dependsOn": ["generate", "^dev"],
      "cache": false,
      "persistent": true
    },
    "dev:api": {
      "cache": false,
      "persistent": true,
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "format": {
      "cache": false
    }
  },
  "globalDependencies": ["**/.env.*local"]
}
