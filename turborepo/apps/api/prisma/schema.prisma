generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["silkroad"]
}

model Item {
  id               Int       @id @default(autoincrement())
  name             String    @unique @db.VarChar(200)
  weight           Decimal   @db.Decimal(8, 2)
  type             ItemType
  task_deliverable Boolean   @default(false)
  icon_url         String?
  offers           Offer[]

  @@map("items")
  @@schema("silkroad")
}

model Npc {
  id                    Int           @id @default(autoincrement())
  name                  String        @unique @db.VarChar(100)
  needs_quest_to_unlock Boolean       @default(false)
  icon_url              String?
  offers                Offer[]
  locations             NpcLocation[]
  npc_quests            NpcQuest[]

  @@map("npcs")
  @@schema("silkroad")
}

model Offer {
  id      Int  @id @default(autoincrement())
  item_id Int
  npc_id  Int
  price   Int
  item    Item @relation(fields: [item_id], references: [id], onDelete: Cascade)
  npc     Npc  @relation(fields: [npc_id], references: [id], onDelete: Cascade)

  @@unique([item_id, npc_id])
  @@map("offers")
  @@schema("silkroad")
}

model City {
  id        Int           @id @default(autoincrement())
  name      String        @unique @db.VarChar(100)
  locations NpcLocation[]

  @@map("cities")
  @@schema("silkroad")
}

model Quest {
  id         Int        @id @default(autoincrement())
  name       String     @unique @db.VarChar(200)
  npc_quests NpcQuest[]

  @@map("quests")
  @@schema("silkroad")
}

model NpcLocation {
  id      Int      @id @default(autoincrement())
  npc_id  Int
  city_id Int
  coord_x Int
  coord_y Int
  coord_z Int      @default(7)
  weekday Weekday?
  npc     Npc      @relation(fields: [npc_id], references: [id], onDelete: Cascade)
  city City @relation(fields: [city_id], references: [id], onDelete: Restrict)

  @@map("npc_locations")
  @@schema("silkroad")
}

model NpcQuest {
  npc_id   Int
  quest_id Int
  npc      Npc   @relation(fields: [npc_id], references: [id], onDelete: Cascade)
  quest    Quest @relation(fields: [quest_id], references: [id], onDelete: Cascade)

  @@id([npc_id, quest_id])
  @@map("npc_quests")
  @@schema("silkroad")
}

enum ItemType {
  Weapon
  Armor
  Ammunition
  Wand
  Rod
  Shield
  Helmet
  Legs
  Boots
  Amulet
  Ring
  Creature_Product @map("Creature Product")
  Food
  Other

  @@schema("silkroad")
}

enum Weekday {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday

  @@schema("silkroad")
}